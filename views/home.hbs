<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zipper</title>
</head>
<body>
    <header>
        <h1>Zipper</h1>
        <p>Zip one or more files.</p>
    </header>
    <main>
        <section>
            <form action="" method="post" enctype="multipart/form-data">
                <div>
                    <label for="input_files">Choose one or multiple files to upload</label>
                    <input
                        type="file"
                        id="input_files"
                        name="input_files"
                        multiple
                    />
                </div>
                <div>
                    <button type="submit">Submit</button>
                </div>
            </form>
        </section>
    </main>
    <footer>
        <div>
            Zipper | Developed by Mitesh Prajapati
        </div>
    </footer>
</body>
</html>
